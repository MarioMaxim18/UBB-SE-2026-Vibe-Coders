<Page
    x:Class="VibeCoders.Views.FocusModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:VibeCoders.ViewModels">

    <Grid Background="Black" Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Center">

                <TextBlock Text="{x:Bind ViewModel.WorkoutSessionTitle, Mode=OneWay}"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextWrapping="WrapWholeWords" />

                <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                    <StackPanel Spacing="4">
                        <TextBlock Text="SESSION TIME" Foreground="Gray" FontSize="12" />
                        <TextBlock Text="{x:Bind ViewModel.WorkoutElapsedDisplay, Mode=OneWay}"
                                   Foreground="LimeGreen" FontSize="36" FontFamily="Consolas" />
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <TextBlock Text="Now" Foreground="Gray" FontSize="12" VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.CurrentExerciseName, Mode=OneWay}"
                                       Foreground="White" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Foreground="Gray" FontSize="12">
                                <Run Text="Set " />
                                <Run Text="{x:Bind ViewModel.CurrentSetNumber, Mode=OneWay}" />
                                <Run Text=" · Target " />
                                <Run Text="{x:Bind ViewModel.CurrentTargetReps, Mode=OneWay}" />
                                <Run Text=" reps" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Spacing="8">
                    <TextBlock Text="Complete Current Set" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <NumberBox Grid.Column="0"
                                   Header="Reps"
                                   Value="{x:Bind ViewModel.CurrentSetRepsInput, Mode=TwoWay}"
                                   Minimum="0"
                                   Maximum="999"
                                   SpinButtonPlacementMode="Compact" />
                        <NumberBox Grid.Column="1"
                                   Header="Weight (kg)"
                                   Value="{x:Bind ViewModel.CurrentSetWeightInput, Mode=TwoWay}"
                                   Minimum="0"
                                   Maximum="9999"
                                   SmallChange="0.5"
                                   SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <Button Content="Complete Set"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CompleteCurrentSetCommand}" />
                </StackPanel>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.ExerciseRows, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActiveExerciseViewModel">
                            <StackPanel Spacing="8" Margin="0,12,0,0">
                                <TextBlock Text="{x:Bind ExerciseName}" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                                <ItemsRepeater ItemsSource="{x:Bind Sets, Mode=OneWay}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActiveSetViewModel">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,4,0,0">
                                                <TextBlock Foreground="Gray" VerticalAlignment="Center">
                                                    <Run Text="Set " /><Run Text="{x:Bind SetIndex}" /><Run Text=" · " />
                                                </TextBlock>
                                                <TextBlock Foreground="White" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind TargetReps}" /><Run Text=" reps" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Button Content="Exit Focus Mode"
                        HorizontalAlignment="Center"
                        Width="220"
                        Height="48"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ExitButton_Click" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
