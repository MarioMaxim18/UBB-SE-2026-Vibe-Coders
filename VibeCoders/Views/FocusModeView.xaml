<Page
    x:Class="VibeCoders.Views.FocusModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:VibeCoders.ViewModels">

    <Grid Background="Black">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

            <TextBlock Text="{Binding SelectedTemplate.WorkoutName}" 
                       Foreground="White" FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <ItemsRepeater>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ActiveExerciseViewModel">
                        <StackPanel Margin="0,10">
                            <TextBlock Text="{x:Bind ExerciseName}" Foreground="White" FontSize="24"/>
                            <ItemsRepeater ItemsSource="{x:Bind Sets}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ActiveSetViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{x:Bind SetIndex}" Foreground="White"/>
                                            <TextBlock Text="{x:Bind TargetReps}" Foreground="White"/>
                                            <TextBlock Text="{x:Bind TargetWeight}" Foreground="White"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Button Content="Finish Workout" Width="200" Height="50"
                     />
        </StackPanel>
    </Grid>
</Page>