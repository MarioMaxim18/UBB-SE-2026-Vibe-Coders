<UserControl
    x:Class="VibeCoders.Views.MealBuilderForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:viewmodels="using:VibeCoders.ViewModels">

    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8" Padding="24" Margin="10">

        <StackPanel>
            <TextBlock Text="Build a Meal"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- ── Meal Name ───────────────────────────────────────────── -->
            <TextBlock Text="Meal Name"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBox Text="{x:Bind ViewModel.MealName, Mode=TwoWay}"
                     PlaceholderText="e.g. Grilled Chicken Bowl"
                     Padding="8" Margin="0,0,0,16"
                     FontSize="14"/>

            <!-- ── Ingredients ────────────────────────────────────────── -->
            <TextBlock Text="Ingredients"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <!-- Text input + Add button -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.CurrentIngredientInput, Mode=TwoWay}"
                         PlaceholderText="e.g. 200g chicken breast"
                         Padding="8" Margin="0,0,8,0" FontSize="14"/>

                <Button Grid.Column="1"
                        Content="Add"
                        Command="{x:Bind ViewModel.AddIngredientCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        Padding="16,8"/>
            </Grid>

            <!-- Tag chips — one per ingredient -->
            <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.Ingredients, Mode=OneWay}"
                                Margin="0,0,0,16">
                <muxc:ItemsRepeater.Layout>
                    <muxc:FlowLayout Orientation="Horizontal"
                                     MinItemSpacing="8"
                                     LineSpacing="8"/>
                </muxc:ItemsRepeater.Layout>
                <muxc:ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:IngredientItem">
                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                CornerRadius="12" Padding="10,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind Text}"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                                <Button Content="✕"
                                        Command="{x:Bind RemoveCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        FontSize="11"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </muxc:ItemsRepeater.ItemTemplate>
            </muxc:ItemsRepeater>

            <!-- ── Preparation Instructions ───────────────────────────── -->
            <TextBlock Text="Preparation Instructions"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBox Text="{x:Bind ViewModel.Instructions, Mode=TwoWay}"
                     PlaceholderText="Describe how to prepare this meal…"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="120"
                     Padding="8"
                     Margin="0,0,0,24"
                     FontSize="14"/>

            <!-- ── Save Button ─────────────────────────────────────────── -->
            <Button Content="Save Meal"
                    Command="{x:Bind ViewModel.SaveMealCommand}"
                    HorizontalAlignment="Stretch"
                    Style="{ThemeResource AccentButtonStyle}"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Padding="0,12"/>
        </StackPanel>
    </Border>
</UserControl>
