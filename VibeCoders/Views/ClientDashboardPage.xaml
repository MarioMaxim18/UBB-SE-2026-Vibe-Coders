<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.ClientDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VibeCoders.ViewModels"
    xmlns:models="using:VibeCoders.Models.Analytics"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32,24,32,32" Spacing="24" MaxWidth="1200">

                <!-- Header row -->
                <Grid>
                    <TextBlock
                        Text="Analytics Dashboard"
                        Style="{StaticResource TitleTextBlockStyle}"
                        VerticalAlignment="Center" />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- KPI Summary Cards -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Total Workouts"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.TotalWorkouts, Mode=OneWay}"
                                       Style="{StaticResource HeaderTextBlockStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Active Time (7 Days)"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.ActiveTimeSevenDaysDisplay, Mode=OneWay}"
                                       Style="{StaticResource HeaderTextBlockStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Preferred Workout"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.PreferredWorkoutDisplay, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Consistency Chart (control added in code-behind) -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="4-Week Consistency"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,12" />
                        <Grid x:Name="ChartContainer" Height="220" />
                        <ProgressRing
                            IsActive="{x:Bind ViewModel.IsLoadingChart, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsLoadingChart, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Width="32" Height="32"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Workout History -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Workout History"
                               Style="{StaticResource SubtitleTextBlockStyle}" />

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.HistoryItems, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkoutHistoryItemViewModel">
                                <Expander
                                    IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,4">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,4">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind DateLine}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind DurationLine}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Expander.Header>
                                    <Expander.Content>
                                        <StackPanel>
                                            <ProgressRing
                                                IsActive="{x:Bind IsLoadingDetail, Mode=OneWay}"
                                                Width="20" Height="20"
                                                HorizontalAlignment="Center"
                                                Margin="0,8" />
                                            <Grid ColumnDefinitions="2*,*,*,*" Margin="0,0,0,8">
                                                <TextBlock Text="Exercise" FontWeight="SemiBold"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                <TextBlock Grid.Column="1" Text="Set" FontWeight="SemiBold"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                <TextBlock Grid.Column="2" Text="Reps" FontWeight="SemiBold"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                <TextBlock Grid.Column="3" Text="Weight" FontWeight="SemiBold"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{x:Bind Sets, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:WorkoutSetRow">
                                                        <Grid ColumnDefinitions="2*,*,*,*" Padding="0,3">
                                                            <TextBlock Text="{x:Bind ExerciseName}" />
                                                            <TextBlock Grid.Column="1" Text="{x:Bind SetIndex}" />
                                                            <TextBlock Grid.Column="2" Text="{x:Bind RepsDisplay}" />
                                                            <TextBlock Grid.Column="3" Text="{x:Bind WeightDisplay}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander.Content>
                                </Expander>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Loading spinner for history -->
                    <ProgressRing
                        IsActive="{x:Bind ViewModel.IsLoadingHistory, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoadingHistory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        Width="32" Height="32"
                        HorizontalAlignment="Center"
                        Margin="0,8" />

                    <!-- Empty state -->
                    <StackPanel
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Padding="0,32">
                        <FontIcon Glyph="&#xE787;" FontSize="40"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No workouts recorded yet"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Complete a workout to see your analytics here."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Pagination controls -->
                    <Grid
                        ColumnDefinitions="Auto,*,Auto"
                        Margin="0,8,0,0"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <Button Content="Previous"
                                Command="{x:Bind ViewModel.PreviousPageCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoPrevious, Mode=OneWay}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.PageDisplayText, Mode=OneWay}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="Next"
                                Command="{x:Bind ViewModel.NextPageCommand}"
                                IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
