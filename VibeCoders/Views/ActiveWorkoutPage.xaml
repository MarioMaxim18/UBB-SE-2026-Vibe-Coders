<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VibeCoders.Views.ActiveWorkoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:VibeCoders.ViewModels"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid>
        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Top">
            <StackPanel
                Padding="20,20,28,32"
                Spacing="28"
                HorizontalAlignment="Stretch">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- Header -->
                <Grid>
                    <TextBlock
                        Text="Active Workout"
                        Style="{StaticResource TitleTextBlockStyle}"
                        VerticalAlignment="Center" />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.FinishWorkoutCommand}"
                        CommandParameter="{x:Bind ClientId}"
                        IsEnabled="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" FontSize="14" />
                            <TextBlock Text="Finish Workout" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Error message -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBool}}"
                    Severity="Error"
                    Title="Error"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                <!-- Available Workouts Dropdown (#68 collapsed container) -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                    <StackPanel Spacing="16">
                        <Grid>
                            <TextBlock
                                Text="Available Workouts for You"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                VerticalAlignment="Center" />
                            <ProgressRing
                                HorizontalAlignment="Right"
                                IsActive="{x:Bind ViewModel.IsLoadingWorkouts, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsLoadingWorkouts, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Width="20" Height="20" />
                        </Grid>

                        <ComboBox
                            PlaceholderText="Select a workout to begin..."
                            ItemsSource="{x:Bind ViewModel.AvailableWorkouts, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedTemplate, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkoutTemplate">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE14C;" FontSize="14"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{x:Bind Name}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Active Exercise List -->
                <ItemsRepeater
                    ItemsSource="{x:Bind ViewModel.ExerciseRows, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActiveExerciseViewModel">

                            <!-- Exercise Card (#68 collapsed container layout) -->
                            <Expander
                                IsExpanded="True"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                CornerRadius="8"
                                Margin="0,0,0,12">

                                <!-- Expand/Collapse Header (#69) -->
                                <Expander.Header>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE14C;" FontSize="16"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock
                                                Text="{x:Bind ExerciseName}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="{x:Bind MuscleGroup}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- System Adjusted Badge (#70) -->
                                        <Border
                                            Grid.Column="1"
                                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                            BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{x:Bind IsSystemAdjusted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                            VerticalAlignment="Center">
                                            <ToolTipService.ToolTip>
                                                <!-- Tooltip UI for progression math (#71) -->
                                                <ToolTip>
                                                    <StackPanel Spacing="4" MaxWidth="300">
                                                        <TextBlock
                                                            Text="System Adjusted"
                                                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        <TextBlock
                                                            Text="{x:Bind AdjustmentNote, Mode=OneWay}"
                                                            Style="{StaticResource CaptionTextBlockStyle}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </ToolTip>
                                            </ToolTipService.ToolTip>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7BA;" FontSize="12"
                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                                <TextBlock
                                                    Text="System Adjusted"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Expander.Header>

                                <!-- Set Rows (#72) -->
                                <Expander.Content>
                                    <StackPanel Spacing="4" Padding="0,8,0,12">

                                        <!-- Column headers -->
                                        <Grid ColumnDefinitions="32,*,120,120,Auto" Padding="0,0,0,8">
                                            <TextBlock Text="#"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="Exercise"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="Reps"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="Weight (kg)"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Grid>

                                        <ItemsRepeater ItemsSource="{x:Bind Sets, Mode=OneWay}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ActiveSetViewModel">

                                                    <!-- Set Row (#72) -->
                                                    <Border
                                                        CornerRadius="4"
                                                        Padding="0,6"
                                                        Margin="0,2">
                                                        <Border.Background>
                                                            <SolidColorBrush
                                                                Color="{ThemeResource SubtleFillColorTransparent}" />
                                                        </Border.Background>
                                                        <Grid ColumnDefinitions="32,*,120,120,Auto" ColumnSpacing="8">

                                                            <!-- Set index -->
                                                            <Border
                                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                CornerRadius="12"
                                                                Width="24" Height="24"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                                <TextBlock
                                                                    Text="{x:Bind SetIndex}"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                            </Border>

                                                            <!-- Target info -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                    <Run Text="Target: " />
                                                                    <Run Text="{x:Bind TargetReps}" />
                                                                    <Run Text=" reps @ " />
                                                                    <Run Text="{x:Bind TargetWeight}" />
                                                                    <Run Text=" kg" />
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- Actual Reps input -->
                                                            <NumberBox
                                                                Grid.Column="2"
                                                                Value="{x:Bind ActualRepsValue, Mode=TwoWay}"
                                                                Minimum="0"
                                                                Maximum="999"
                                                                SpinButtonPlacementMode="Compact"
                                                                PlaceholderText="Reps"
                                                                IsEnabled="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolNegate}}"
                                                                HorizontalAlignment="Stretch" />

                                                            <!-- Actual Weight input -->
                                                            <NumberBox
                                                                Grid.Column="3"
                                                                Value="{x:Bind ActualWeightValue, Mode=TwoWay}"
                                                                Minimum="0"
                                                                Maximum="9999"
                                                                SmallChange="0.5"
                                                                SpinButtonPlacementMode="Compact"
                                                                PlaceholderText="kg"
                                                                IsEnabled="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolNegate}}"
                                                                HorizontalAlignment="Stretch" />

                                                            <!-- Done button / completed check -->
                                                            <Button
                                                                Grid.Column="4"
                                                                VerticalAlignment="Center"
                                                                Visibility="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                                <FontIcon Glyph="&#xE73E;" FontSize="14" />
                                                            </Button>
                                                            <FontIcon
                                                                Grid.Column="4"
                                                                Glyph="&#xE73E;"
                                                                FontSize="16"
                                                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                        </Grid>
                                                    </Border>

                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>

                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Notifications Section (#73) -->
                <StackPanel
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        Text="Notifications"
                        Style="{StaticResource SubtitleTextBlockStyle}" />

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:Notification">

                                <!-- Notification List Item (#73) -->
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">

                                        <!-- Notification icon -->
                                        <FontIcon
                                            Glyph="&#xE7BA;"
                                            FontSize="24"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            VerticalAlignment="Center" />

                                        <!-- Title + message -->
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock
                                                Text="{x:Bind Title}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                Text="{x:Bind Message}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Confirm Deload button (#73) -->
                                        <Button
                                            Grid.Column="2"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Center"
                                            Tag="{x:Bind}"
                                            Click="ConfirmDeloadButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                <TextBlock Text="Confirm Deload" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Finish button at bottom -->
                <Button
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.FinishWorkoutCommand}"
                    CommandParameter="{x:Bind ClientId}"
                    IsEnabled="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing
                            IsActive="{x:Bind ViewModel.IsFinishing, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsFinishing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Width="16" Height="16" />
                        <FontIcon Glyph="&#xE73E;" FontSize="14" />
                        <TextBlock Text="Finish Workout" />
                    </StackPanel>
                </Button>

                <!-- Repeat This Workout button (#77) -->
                <Button
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.RepeatWorkoutCommand}"
                    CommandParameter="{x:Bind ClientId}"
                    Visibility="{x:Bind ViewModel.IsWorkoutStarted, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="Repeat This Workout" />
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
