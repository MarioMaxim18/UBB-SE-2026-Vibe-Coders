<UserControl
    x:Class="VibeCoders.Views.CreateWorkoutView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="1100">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="20">
        <StackPanel Spacing="6">
            <TextBlock Text="Create Workout" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Build a custom routine and save it to My Saved Workouts."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Workout name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox Text="{Binding WorkoutName, Mode=TwoWay}" PlaceholderText="Enter workout name" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Spacing="16">
                <TextBlock Text="Exercises in this Routine" Style="{StaticResource BodyStrongTextBlockStyle}" />

                <ListView Height="170"
                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                          CornerRadius="4"
                          Padding="4"
                          HorizontalContentAlignment="Stretch"
                          ItemsSource="{Binding Exercises}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TemplateExercise">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="(" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TargetSets}" Foreground="Gray"/>
                                    <TextBlock Text="×" Foreground="Gray"/>
                                    <TextBlock Text="{x:Bind TargetReps}" Foreground="Gray"/>
                                    <TextBlock Text=")" Foreground="Gray"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Remove"
                                        Command="{Binding DataContext.RemoveExerciseCommand, ElementName=Root}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid ColumnSpacing="8" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Row="0" Grid.Column="0"
                              Header="Select Exercise"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose..."
                              ItemsSource="{Binding AvailableExercises}"
                              SelectedItem="{Binding SelectedNewExercise, Mode=TwoWay}"/>

                    <NumberBox Grid.Row="0" Grid.Column="1"
                               Header="Sets"
                               Minimum="1"
                               Maximum="10"
                               Value="{Binding NewExerciseSets, Mode=TwoWay}"/>

                    <NumberBox Grid.Row="0" Grid.Column="2"
                               Header="Reps"
                               Minimum="1"
                               Maximum="100"
                               Value="{Binding NewExerciseReps, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="0" Grid.Column="3"
                               VerticalAlignment="Bottom"
                               Text="No target weight"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <Button Grid.Row="1" Grid.ColumnSpan="4"
                            Content="+ Add to Routine"
                            HorizontalAlignment="Stretch"
                            Command="{Binding AddExerciseCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="Save Workout" Command="{Binding SaveWorkoutCommand}" />
        </StackPanel>
    </Grid>
</UserControl>