<UserControl
    x:Class="VibeCoders.Views.CreateWorkoutView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:VibeCoders.Models"
    mc:Ignorable="d"
    d:DesignHeight="700"
    d:DesignWidth="1100">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="20">
        <StackPanel Spacing="6">
            <TextBlock Text="Create Workout" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Build a custom routine and save it to My Saved Workouts."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Workout name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox Text="{Binding WorkoutName, Mode=TwoWay}" PlaceholderText="Enter workout name" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Spacing="16">
                <Grid ColumnSpacing="8" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        Grid.Column="0"
                        Header="Select exercise"
                        PlaceholderText="Choose..."
                        ItemsSource="{Binding AvailableExercises}"
                        SelectedItem="{Binding SelectedNewExercise, Mode=TwoWay}" />

                    <NumberBox
                        Grid.Column="1"
                        Header="Sets"
                        Minimum="1"
                        Maximum="10"
                        Value="{Binding NewExerciseSets, Mode=TwoWay}" />

                    <NumberBox
                        Grid.Column="2"
                        Header="Reps"
                        Minimum="1"
                        Maximum="100"
                        Value="{Binding NewExerciseReps, Mode=TwoWay}" />

                    <Button
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Content="+ Add"
                        Command="{Binding AddExerciseCommand}" />
                </Grid>

                <Grid ColumnDefinitions="2*,*,*,Auto,Auto" ColumnSpacing="12">
                    <TextBlock Text="Exercise" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="Sets" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="Reps" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="Muscle group" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="" />
                </Grid>

                <ListView ItemsSource="{Binding Exercises}" SelectionMode="None" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TemplateExercise">
                            <Grid ColumnDefinitions="2*,*,*,Auto,Auto" ColumnSpacing="12" Margin="0,0,0,10">
                                <TextBox Text="{Binding Name, Mode=TwoWay}" PlaceholderText="Exercise name" />
                                <NumberBox Grid.Column="1" Value="{Binding TargetSets, Mode=TwoWay}" Minimum="1" Maximum="12" SpinButtonPlacementMode="Compact" />
                                <NumberBox Grid.Column="2" Value="{Binding TargetReps, Mode=TwoWay}" Minimum="0" Maximum="100" SpinButtonPlacementMode="Compact" />
                                <ComboBox
                                    Grid.Column="3"
                                    ItemsSource="{Binding DataContext.MuscleGroups, ElementName=Root}"
                                    SelectedItem="{Binding MuscleGroup, Mode=TwoWay}"
                                    MinWidth="140" />
                                <Button
                                    Grid.Column="4"
                                    Command="{Binding DataContext.RemoveExerciseCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    Content="Remove" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="Save Workout" Command="{Binding SaveWorkoutCommand}" />
        </StackPanel>
    </Grid>
</UserControl>